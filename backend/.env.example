# Database
DATABASE_URL=postgresql://duoextra:duoextra_dev_pass@localhost:5432/duoextra

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=duoextra
S3_SECRET_KEY=duoextra_minio_pass
S3_BUCKET=duoextra-media
S3_REGION=us-east-1

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# AI Services (add your keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email (add your SMTP config)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@duoextra.com
